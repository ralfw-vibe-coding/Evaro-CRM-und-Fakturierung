# Secret password that can be used instead of an emailed OTP (see tech-stack.md)
AUTH_SECRET_OTP=changeme

# JWT signing secret
AUTH_JWT_SECRET=changeme

# Static API key for non-interactive backend clients
API_KEY=changeme

# Neon Postgres connection string. If unset, the backend uses an in-memory store.
DATABASE_URL=

# Persistence backend: "postgres" (requires DATABASE_URL) or "memory"
PERSISTENCE=memory
